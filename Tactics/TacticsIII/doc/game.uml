@startuml

interface World {
   bool Obstacle(Position, Actor except)
}

class Game {

}

interface BlockMap {
   Height(Position): int
}

class Map {
   + size
}

interface Actor {
   position
   Move(position, Map)
}

Actor *--> "appearance" Engine.UI.Scenery

World o--> BlockMap
Game ...|> World
Game *---> Map
Map ..|> BlockMap
class Avatar
Avatar ...|> Actor
Game *--> "*" Avatar
Map ...|> Engine.UI.Scenery
Avatar ...|> Engine.UI.Scenery
Game o--> Engine.UI.Scene
Engine.UI.Scene o--> "*" Engine.UI.Scenery
@enduml
